{
  "name": "tnfportal_mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-firebase/analytics": "^25.1.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/crashlytics": "^25.1.0",
    "@sentry/react-native": "^8.16.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.15.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-google-mobile-ads": "^15.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:localhost": "expo start --localhost",
    "start:ios": "expo start --lan --ios",
    "android": "expo run:android",
    "ios": "expo start --ios --localhost",
    "ios:build": "expo run:ios --device \"iPhone 17\"",
    "functions:deploy": "firebase deploy --only functions",
    "ios:build:sim": "xcodebuild -downloadPlatform iOS && npm run ios:build",
    "test:e2e:ios": "maestro test --config .maestro/config.yaml --device $(xcrun simctl list devices booted | grep -oE '[A-F0-9-]{36}' | head -1) .maestro/flows/volunteer-chat-e2e.yaml",
    "web": "expo start --web",
    "eas:secrets": "bash scripts/eas-upload-secrets.sh",
    "eas-build-pre-install": "node scripts/materialize-firebase-config.js --required",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:ios:preview": "eas build --profile preview-ios --platform ios",
    "build:android:production": "eas build --profile production --platform android",
    "build:ios:production": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --platform ios --latest --profile production"
  },
  "private": true
}
