# API base URL (no trailing slash)
# Local dev:
#   iOS simulator: http://localhost:8000
#   Android emulator: http://10.0.2.2:8000
#   Physical device: http://<your-computer-lan-ip>:8000
# Production (EAS preview + production builds use eas.json — do not change here for store builds):
#   https://ngo.cipree.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# Default tenant slug shown on the login screen
EXPO_PUBLIC_TENANT_SLUG=ganaa-regression

# Firebase (Firestore chat + Crashlytics/Analytics in native builds)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# AdMob (Google test app IDs are configured in app.json until you add real units)
EXPO_PUBLIC_ADMOB_ENABLED=true
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=

# Sentry (errors, session replay, distributed tracing to Laravel API)
# DSN from Sentry → Settings → Projects → tnfportal_mobile → Client Keys
EXPO_PUBLIC_SENTRY_DSN=
