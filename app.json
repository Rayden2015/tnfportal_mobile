{
  "expo": {
    "name": "TNF Portal",
    "slug": "tnfportal_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tnfportalmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./myfirebase/GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TNF Portal uses your location to verify volunteer check-ins when geo-fencing is enabled."
      },
      "bundleIdentifier": "com.infinixel.cipreengo"
    },
    "android": {
      "package": "com.infinixel.cipreengo",
      "googleServicesFile": "./myfirebase/google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#EA580C"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TNF Portal uses your location to verify volunteer check-ins when geo-fencing is enabled."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sharing",
      "@react-native-firebase/app",
      [
        "@react-native-firebase/crashlytics",
        {
          "crashlytics_debug_enabled": true
        }
      ],
      "@react-native-firebase/analytics",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "tnfportal_mobile",
          "organization": "infinixel"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:8000",
      "router": {},
      "eas": {
        "projectId": "dbca283f-355b-42e6-9f90-b9f5371090e7"
      }
    },
    "owner": "nurundin2010",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dbca283f-355b-42e6-9f90-b9f5371090e7"
    }
  }
}
